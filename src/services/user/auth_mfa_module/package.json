    "jsonwebtoken": "9.0.2",
    "otplib": "12.0.1",
    "pg": "8.12.0",
    "pino": "9.3.2",
    "qrcode": "1.5.4",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "9.0.6",
    "@types/node": "20.14.10",
    "@types/pg": "8.11.6",
    "@types/qrcode": "1.5.5",
    "@typescript-eslint/eslint-plugin": "7.14.1",
    "@typescript-eslint/parser": "7.14.1",
    "eslint": "8.57.0",
    "prettier": "3.3.2",
    "typescript": "5.5.3"
  },
