{
  "name": "@acn/auth-mfa-module",
  "version": "1.0.0",
  "description": "Production-grade Authentication and MFA module for high-concurrency ecommerce backend",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
